# MAX Bot API token (get from MasterBot in MAX)
MAX_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# MAX API base URL
MAX_API_BASE_URL=https://platform-api.max.ru

# Hermes webhook settings
HERMES_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/max-bot
HERMES_WEBHOOK_SECRET=max-bridge-secret-change-me

# Bridge settings
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8787
BRIDGE_SECRET=max-bridge-secret-change-me

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/max-bridge/bridge.log

# Allowed users (comma-separated user IDs, empty = allow all)
ALLOWED_USERS=

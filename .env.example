# MAX Bot API token (get from MAX partner platform)
MAX_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# MAX API base URL
MAX_API_BASE_URL=https://platform-api.max.ru

# Hermes CLI settings
HERMES_BIN=hermes
HERMES_MODEL=
HERMES_TIMEOUT=120

# Bridge settings
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8787

# Logging
LOG_LEVEL=INFO

# Allowed users (comma-separated user IDs, empty = allow all)
ALLOWED_USERS=
